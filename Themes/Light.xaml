<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="WindowForeground" Color="Black"/>
    <SolidColorBrush x:Key="BorderBrushColor" Color="#BBBBBB"/>
    <SolidColorBrush x:Key="PanelBackground" Color="White"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#111111"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#333333"/>
    <SolidColorBrush x:Key="ToolbarBackground" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="StatusBackground" Color="#E2E2E2"/>
    
    <SolidColorBrush x:Key="ButtonBg" Color="#E1E1E1"/>
    <SolidColorBrush x:Key="ButtonHover" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="ButtonPress" Color="#BBBBBB"/>
    <SolidColorBrush x:Key="ButtonBorder" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ButtonDisabledBg" Color="#D6D6D6"/>
    <SolidColorBrush x:Key="ButtonDisabledBorder" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ButtonDisabledFg" Color="#666666"/>
    <SolidColorBrush x:Key="ButtonFg" Color="#111111"/>
    
    <SolidColorBrush x:Key="GridHeaderBg" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="GridHeaderBorder" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="GridLines" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="GridAltRow" Color="#F8F8F8"/>
</ResourceDictionary>
