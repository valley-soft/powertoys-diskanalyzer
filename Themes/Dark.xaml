    <SolidColorBrush x:Key="WindowForeground" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="BorderBrushColor" Color="#444444"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ToolbarBackground" Color="#333333"/>
