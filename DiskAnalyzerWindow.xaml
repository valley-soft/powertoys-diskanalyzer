<Window x:Class="Community.PowerToys.Run.Plugin.DiskAnalyzer.DiskAnalyzerWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ValleySoft Disk Analyzer" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}">

    <Window.Resources>
        <!-- Force button to always look the same regardless of dark/light mode -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Style.Triggers CAN use DynamicResource; ControlTemplate triggers with TargetName cannot -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonPress}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ButtonDisabledBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonDisabledBorder}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ButtonDisabledFg}"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView item style to fix dark-mode highlight text -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- DataGrid column header style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GridHeaderBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- DataGrid row style -->
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,10,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: TreeView -->
            <TreeView x:Name="FolderTree" 
                      Grid.Column="0" 
                      BorderThickness="1" 
                      BorderBrush="{DynamicResource BorderBrushColor}"
                      Background="{DynamicResource PanelBackground}"
                      Foreground="{DynamicResource TextPrimary}"
                      ItemsSource="{Binding RootFolders, ElementName=RootWindow}"
                      SelectedItemChanged="FolderTree_SelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <EventSetter Event="Expanded" Handler="FolderTree_Expanded"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource BorderBrushColor}" />

            <!-- Right Pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{DynamicResource ToolbarBackground}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1,1,1,0" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BackButton" Margin="0,0,8,0" Padding="8,4" Click="Back_Click" IsEnabled="{Binding ElementName=RootWindow, Path=CanGoBack}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬅" Margin="0,0,4,0"/>
                                <TextBlock Text="Back"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Margin="0,0,8,0" Padding="8,4" Click="Refresh_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄" Margin="0,0,4,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                        
                        <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" SelectedIndex="0" Width="100" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource ButtonBg}">
                            <ComboBoxItem Content="System" Tag="System"/>
                            <ComboBoxItem Content="Light" Tag="Light"/>
                            <ComboBoxItem Content="Dark" Tag="Dark"/>
                        </ComboBox>
                        
                        <TextBlock x:Name="CurrentPathText" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Results DataGrid -->
                <DataGrid x:Name="ItemsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource GridLines}"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource BorderBrushColor}"
                          Background="{DynamicResource PanelBackground}"
                          RowBackground="{DynamicResource PanelBackground}"
                          AlternatingRowBackground="{DynamicResource GridAltRow}"
                          MouseDoubleClick="ItemsGrid_MouseDoubleClick"
                          Cursor="Hand">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="*" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="100" SortMemberPath="SizeBytes">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Allocated" Binding="{Binding FormattedAllocated}" Width="100" SortMemberPath="AllocatedSizeBytes">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Modified" Binding="{Binding FormattedDate}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="{DynamicResource ToolbarBackground}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="0,1,0,0" Padding="12,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                <ProgressBar x:Name="ScanProgressBar" Margin="8,0" Width="100" Height="4" IsIndeterminate="True" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
