<Window x:Class="Community.PowerToys.Run.Plugin.DiskAnalyzer.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ValleySoft Disk Analyzer Installer" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Icon="AppIcon.ico"
        Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <!-- Modern RadioButton Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ValleySoft Disk Analyzer v1.3.0" FontSize="28" FontWeight="Bold" Foreground="#4A90E2"/>
            <TextBlock Text="Unified Installer" FontSize="16" Foreground="#AAAAAA" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Install Mode -->
        <GroupBox Grid.Row="1" Header="Installation Mode" Foreground="White" BorderBrush="#333333" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <RadioButton x:Name="RadioClean" Content="Clean Install (Recommended)" IsChecked="True"/>
                <TextBlock Text="This will automatically uninstall previous versions, completely wipe out old plugin directories, and cleanly install the self-contained version. It guarantees a flawless setup." Foreground="#AAAAAA" TextWrapping="Wrap" Margin="20,5,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Components -->
        <GroupBox Grid.Row="2" Header="Select Components" Foreground="White" BorderBrush="#333333" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <!-- PowerToys Check -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <CheckBox x:Name="CheckPlugin" Content="PowerToys Run Plugin" IsChecked="True"/>
                    <TextBlock x:Name="TxtPowerToysMissing" Text="(PowerToys is not installed)" Foreground="#FF5555" Margin="10,5,10,5" Visibility="Collapsed" VerticalAlignment="Center"/>
                    <Button x:Name="BtnInstallPowerToys" Content="Install PowerToys" Background="#4A90E2" Foreground="White" BorderThickness="0" Padding="10,2" Margin="0,2,0,2" Visibility="Collapsed" Click="BtnInstallPowerToys_Click"/>
                </StackPanel>
                
                <CheckBox x:Name="CheckCmdPal" Content="Command Palette Extension" IsChecked="True"/>
                <CheckBox x:Name="CheckApp" Content="Standalone Desktop App" IsChecked="True"/>
            </StackPanel>
        </GroupBox>

        <!-- Log Output -->
        <GroupBox Grid.Row="3" Header="Status Log" Foreground="White" BorderBrush="#333333" Padding="5">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Foreground="#00FF00"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Bottom Bar -->
        <Grid Grid.Row="4" Margin="0,15,0,0">
            <ProgressBar x:Name="ProgressBar" Height="30" Minimum="0" Maximum="100" Margin="0,0,120,0" Visibility="Hidden"/>
            <Button x:Name="BtnInstall" Content="Install" HorizontalAlignment="Right" Width="100" Height="35"
                    Background="#4A90E2" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    Click="BtnInstall_Click"/>
        </Grid>
    </Grid>
</Window>
