<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ValleySoft_DiskAnalyzer_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ValleySoft_DiskAnalyzer_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <MenuBar Grid.Row="0" Margin="-12,-12,-12,12">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Select Directory..." Icon="Folder" Click="BrowseButton_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Exit" Icon="Cancel" Click="ExitMenu_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Scan">
                <MenuFlyoutItem Text="Refresh Current" Icon="Refresh" Click="RefreshButton_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="View">
                <ToggleMenuFlyoutItem Text="Show Hidden Files" IsChecked="True" Click="ShowHiddenFiles_Click" x:Name="ShowHiddenFilesToggle"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Expand Root Folders" Icon="Add" Click="ExpandAll_Click"/>
                <MenuFlyoutItem Text="Collapse All" Icon="Remove" Click="CollapseAll_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutSubItem Text="Theme">
                    <MenuFlyoutItem Text="System" Tag="Default" Click="ThemeMenuItem_Click"/>
                    <MenuFlyoutItem Text="Light" Tag="Light" Click="ThemeMenuItem_Click"/>
                    <MenuFlyoutItem Text="Dark" Tag="Dark" Click="ThemeMenuItem_Click"/>
                </MenuFlyoutSubItem>
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            
            <BreadcrumbBar x:Name="PathBreadcrumbBar" Grid.Column="0" VerticalAlignment="Center" ItemClicked="PathBreadcrumbBar_ItemClicked">
                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="16" FontWeight="SemiBold" />
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>

            <Button Grid.Column="1" x:Name="BackButton" Click="BackButton_Click" IsEnabled="False" Height="40" Padding="16,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="Back" />
                </StackPanel>
            </Button>

            <TextBox x:Name="FilterBox" Grid.Column="2" PlaceholderText="Filter (e.g. *.mp4)" VerticalAlignment="Center" Margin="12,0,0,0" TextChanged="FilterBox_TextChanged" />
        </Grid>
        
        <ProgressBar x:Name="ScanProgressBar" Grid.Row="2" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Top" Margin="0,-4,0,0" Canvas.ZIndex="10"/>

        <!-- Main Content area with TreeView and DataGrid -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left pane: TreeView -->
            <Grid Grid.Column="0" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TreeView x:Name="FolderTree" 
                          Expanding="FolderTree_Expanding" 
                          ItemInvoked="FolderTree_ItemInvoked">
                    <!-- Data templates for TreeView will be configured in code behind or here -->
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="local:FolderNode">
                            <TreeViewItem ItemsSource="{x:Bind Children}" HasUnrealizedChildren="{x:Bind HasUnrealizedChildren, Mode=TwoWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Image Source="{x:Bind IconSource}" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- GridSplitter -->
            <controls:GridSplitter Grid.Column="1" Width="12" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right pane: DataGrid -->
            <Grid Grid.Column="2" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Pivot>
                    <PivotItem Header="Details">
                        <controls:DataGrid x:Name="ResultsGrid" 
                            AutoGenerateColumns="False" 
                            IsReadOnly="True" 
                            GridLinesVisibility="Horizontal" 
                            HeadersVisibility="Column" 
                            DoubleTapped="ResultsGrid_DoubleTapped"
                            AlternatingRowBackground="{ThemeResource ControlFillColorTransparentBrush}"
                            RowBackground="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderThickness="0"
                            CanUserResizeColumns="True"
                            CanUserSortColumns="True"
                            Sorting="ResultsGrid_Sorting">
                            <controls:DataGrid.Columns>
                                <controls:DataGridTemplateColumn Header="Name" Tag="Name" Width="*">
                                    <controls:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Padding="12,0,0,0">
                                                <Image Source="{Binding IconSource}" Width="16" Height="16" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </controls:DataGridTemplateColumn.CellTemplate>
                                </controls:DataGridTemplateColumn>
                                <controls:DataGridTemplateColumn Header="% of Parent" Tag="Percentage" Width="120" SortDirection="Descending">
                                    <controls:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center" Spacing="8">
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ParentPercentage}" Height="14" Width="50" Foreground="{ThemeResource AccentFillColorDefaultBrush}" Background="{ThemeResource ControlFillColorTransparentBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                                                <TextBlock Text="{Binding FormattedPercentage}" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </controls:DataGridTemplateColumn.CellTemplate>
                                </controls:DataGridTemplateColumn>
                                <controls:DataGridTextColumn Header="Size" Tag="Size" Binding="{Binding FormattedSize}" Width="120"/>
                                <controls:DataGridTextColumn Header="Allocated" Tag="Allocated" Binding="{Binding FormattedAllocated}" Width="120"/>
                                <controls:DataGridTextColumn Header="Free Space" Tag="FreeSpace" Binding="{Binding FormattedFreeSpace}" Width="100"/>
                                <controls:DataGridTextColumn Header="Files" Tag="Files" Binding="{Binding FileCount}" Width="80"/>
                                <controls:DataGridTextColumn Header="Folders" Tag="Folders" Binding="{Binding FolderCount}" Width="80"/>
                                <controls:DataGridTextColumn Header="Modified" Tag="Modified" Binding="{Binding FormattedDate}" Width="150"/>
                            </controls:DataGrid.Columns>
                        </controls:DataGrid>
                    </PivotItem>
                    <PivotItem Header="Visual Chart">
                        <Grid Padding="24">
                            <ItemsControl x:Name="ChartItemsControl" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChartItemViewModel">
                                        <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{x:Bind ToolTip}">
                                            <Rectangle Width="80" Height="{x:Bind Height}" Fill="{x:Bind Color}" StrokeThickness="1" Stroke="{ThemeResource CardStrokeColorDefaultBrush}" RadiusX="4" RadiusY="4"/>
                                            <TextBlock Text="{x:Bind Name}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" Width="80" FontSize="12" Margin="0,8,0,0" TextAlignment="Center" />
                                            <TextBlock Text="{x:Bind FormattedSize}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Grid>
    </Grid>
</Page>
